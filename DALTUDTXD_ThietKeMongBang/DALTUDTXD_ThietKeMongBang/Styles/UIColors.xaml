<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--Background Colors (Dark theme)-->
    <Color x:Key="primaryBackColor1">#1E1E1E</Color>
    <Color x:Key="primaryBackColor2">#2B2B2B</Color>
    <Color x:Key="secondaryBackColor1">#2F2F2F</Color>
    <Color x:Key="secondaryBackColor2">#3C3C3C</Color>

    <!--Window Border Colors-->
    <Color x:Key="winBorderColor1">#3C3C3C</Color>
    <Color x:Key="winBorderColor2">#5A5A5A</Color>
    <Color x:Key="winBorderColor3">#777777</Color>

    <!--Color Palette-->
    <SolidColorBrush x:Key="color1" Color="#5C9EFF"/>
    <SolidColorBrush x:Key="color2" Color="#61C3FF"/>
    <SolidColorBrush x:Key="color3" Color="#62E8E2"/>
    <SolidColorBrush x:Key="color4" Color="#FF6161"/>
    <SolidColorBrush x:Key="color5" Color="#B46CFF"/>
    <SolidColorBrush x:Key="color6" Color="#FFBC5A"/>
    <SolidColorBrush x:Key="color7" Color="#F46CB3"/>
    <SolidColorBrush x:Key="color8" Color="#6FA8FF"/>
    <SolidColorBrush x:Key="color9" Color="#00EFB3"/>
    <SolidColorBrush x:Key="color10" Color="#FF7F7F"/>

    <!-- Additional UI brushes referenced by styles -->
    <SolidColorBrush x:Key="plainTextColor3" Color="#CCCCCC"/>
    <SolidColorBrush x:Key="panelActiveColor" Color="#2B6EA3"/>



</ResourceDictionary>